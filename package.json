{
  "name": "@lastarla/openclaw-message-attachments",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw plugin for downloading message attachments to local files.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lastarla/openclaw-message-attachments.git"
  },
  "homepage": "https://github.com/lastarla/openclaw-message-attachments",
  "bugs": {
    "url": "https://github.com/lastarla/openclaw-message-attachments/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "feishu",
    "attachments"
  ],
  "files": [
    "index.ts",
    "src",
    "openclaw.plugin.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": ["./index.ts"]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --test dist/tests/**/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}